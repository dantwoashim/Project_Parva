# Project Parva local development defaults
# Copy to .env and adjust only the values you need for your environment.

# Core runtime
PARVA_ENV=development
PARVA_LICENSE_MODE=AGPL-3.0-or-later
PARVA_SOURCE_URL=https://github.com/example/project-parva
PARVA_SERVE_FRONTEND=false
PARVA_FRONTEND_DIST=./frontend/dist

# Public API shape
PARVA_ENABLE_EXPERIMENTAL_API=false
PARVA_ALLOW_EXPERIMENTAL_IN_PROD=false
PARVA_MAX_REQUEST_BYTES=1048576
PARVA_MAX_QUERY_LENGTH=4096

# Auth and partner overlays
# Leave blank for local development unless you are explicitly testing protected surfaces.
PARVA_ADMIN_TOKEN=
PARVA_API_KEYS=

# Rate limiting and cache
PARVA_RATE_LIMIT_ENABLED=true
PARVA_RATE_LIMIT_BACKEND=memory
PARVA_REDIS_URL=
PARVA_REQUIRE_PRECOMPUTED=false
PARVA_PREWARM_HOTSET=false
PARVA_PRECOMPUTED_STALE_HOURS=720
PARVA_RUNTIME_CACHE_ENABLED=true
PARVA_RUNTIME_CACHE_MAX_ENTRIES=128
PARVA_TRUSTED_PROXY_IPS=

# Place search
PARVA_PLACE_SEARCH_ALLOW_REMOTE=true
PARVA_PLACE_SEARCH_PROVIDER_CHAIN=offline,nominatim
PARVA_PLACE_SEARCH_ENDPOINT=https://nominatim.openstreetmap.org/search
PARVA_PLACE_SEARCH_USER_AGENT=ProjectParva/3.0 (+https://example.com/contact)
PARVA_PLACE_SEARCH_TIMEOUT_SECONDS=5.0
PARVA_PLACE_SEARCH_TIME_BUDGET_SECONDS=8.0
PARVA_PLACE_SEARCH_RETRY_ATTEMPTS=2
PARVA_PLACE_SEARCH_RETRY_BACKOFF_SECONDS=0.3
PARVA_PLACE_SEARCH_CACHE_TTL_SECONDS=3600

# Provenance signing
PARVA_PROVENANCE_ATTESTATION_KEY=
PARVA_PROVENANCE_ATTESTATION_KEY_FILE=
PARVA_PROVENANCE_ATTESTATION_KEY_ID=
PARVA_PROVENANCE_ATTESTATION_KEY_ID_FILE=
PARVA_BUILD_SHA=
PARVA_RELEASE_SHA=

# Frontend development
PARVA_DEV_API_TARGET=http://127.0.0.1:8000
VITE_API_BASE=/v3/api
VITE_API_TIMEOUT_MS=10000

# Optional deployment/runtime integrations
CORS_ALLOW_ORIGINS=http://localhost:5173
TELEGRAM_BOT_TOKEN=
