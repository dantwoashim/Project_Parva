exports[`visual regression harness > festival detail page visual baseline 1`] = `
<section
  class="fd-page animate-fade-in-scale"
  style="--accent: var(--vermillion);"
>
  <div
    class="fd-shell"
  >
    <button
      class="btn btn-secondary fd-back"
      type="button"
    >
      Back to festivals
    </button>
    <header
      class="fd-hero ink-card"
    >
      <div
        class="fd-hero__copy"
      >
        <div
          class="fd-hero__eyebrow-row"
        >
          <span
            class="badge"
          >
            national
          </span>
          <span
            class="fd-hero__meta-pill"
          >
