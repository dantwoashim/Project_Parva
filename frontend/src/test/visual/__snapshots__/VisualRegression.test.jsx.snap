exports[`visual regression harness > kundali page visual baseline 1`] = `
<section
  class="kundali-reset animate-fade-in-up consumer-route consumer-route--analysis"
>
  <header
    class="kundali-reset__hero"
  >
    <div>
      <p
        class="kundali-reset__eyebrow"
      >
        Birth Reading
      </p>
      <h1>
        Enter the birth details first.
      </h1>
      <p
        class="kundali-reset__intro"
      >
        Generate the natal chart from the actual birth date, exact time, and birth place. The reading starts with ascendant, moon placement, and the strongest graha.
      </p>
    </div>
  </header>
  <div
    class="kundali-reset__layout"
  >
    <form
      class="kundali-reset__form-card"
    >
      <div
        class="kundali-reset__section-head"
      >
        <div>
          <p
            class="kundali-reset__eyebrow"
          >
            Birth details
          </p>
          <h2>
            Required inputs
          </h2>
        </div>
      </div>
      <div
        class="kundali-reset__date-grid"
      >
        <label
          class="ink-input"
        >
          <span>
            Day
          </span>
          <input
            inputmode="numeric"
            value=""
          />
        </label>
        <label
          class="ink-input"
        >
          <span>
            Month
          </span>
          <input
            inputmode="numeric"
            value=""
          />
        </label>
        <label
          class="ink-input"
        >
          <span>
            Year
          </span>
          <input
            inputmode="numeric"
            value=""
          />
        </label>
        <label
          class="ink-input"
        >
          <span>
            Birth time
          </span>
          <input
            type="time"
            value=""
          />
        </label>
      </div>
      <div
        class="kundali-reset__place-block"
      >
        <div
          class="kundali-reset__section-head"
        >
          <div>
            <p
              class="kundali-reset__eyebrow"
            >
              Birth place
            </p>
            <h2>
              Search and select
            </h2>
          </div>
        </div>
        <div
          class="kundali-reset__place-search"
        >
          <label
            class="ink-input kundali-reset__place-input"
          >
            <span>
              Place
            </span>
            <input
              placeholder="Kathmandu, Nepal"
              type="search"
              value=""
            />
          </label>
          <button
            class="btn btn-secondary"
            type="button"
          >
            Search place
          </button>
        </div>
        <button
          class="kundali-reset__advanced-toggle"
          type="button"
        >
          Show manual coordinates
        </button>
      </div>
      <button
        class="btn btn-primary"
        type="submit"
      >
        Generate chart
      </button>
    </form>
    <aside
      class="kundali-reset__anchors"
    >
      <article
        class="kundali-reset__anchor-card"
      >
        <p
          class="kundali-reset__eyebrow"
        >
          Reading flow
        </p>
        <h2>
          Three anchors, then detail.
        </h2>
        <p>
          Start with the ascendant, then moon placement, then the strongest graha. After that, open houses or aspects only when you need more structure.
        </p>
      </article>
      <article
        class="kundali-reset__anchor-card"
      >
        <span>
          Outer style
        </span>
        <strong>
          Lagna pending
        </strong>
      </article>
      <article
        class="kundali-reset__anchor-card"
      >
        <span>
          Inner weather
        </span>
        <strong>
          Moon placement pending
        </strong>
      </article>
      <article
        class="kundali-reset__anchor-card"
      >
        <span>
          Strongest pull
        </span>
        <strong>
