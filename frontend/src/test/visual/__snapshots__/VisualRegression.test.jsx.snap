          class="festival-detail__truth-note"
        >
          No alternate authority-backed candidates are published for this festival-year.
        </p>
      </article>
    </div>
  </section>
  <section
    class="festival-detail__technical"
  >
    <div
      class="festival-detail__technical-copy"
    >
      <div>
        <p
          class="festival-detail__eyebrow"
        >
          Method details
        </p>
        <h2>
          Open the evidence only when you want it.
        </h2>
      </div>
      <p>
        The main page stays editorial. Trace and technical detail remain available without overwhelming the ritual story.
      </p>
    </div>
    <div
      class="festival-detail__technical-actions"
    >
      <button
        class="btn btn-secondary"
        type="button"
      >
        View technical trace
      </button>
      <button
        class="btn btn-secondary"
        type="button"
      >
        Remind me
      </button>
      <button
        class="btn btn-secondary evidence-drawer__trigger"
        type="button"
      >
        How this was calculated
      </button>
    </div>
  </section>
</section>
`;

