      <button
        class="btn btn-secondary evidence-drawer__trigger"
        type="button"
      >
        How this was calculated
      </button>
      <section
        aria-label="How Personal Panchanga Is Different"
        class="knowledge-panel ink-card personal-knowledge"
      >
        <header
          class="knowledge-panel__header"
        >
          <p
            class="knowledge-panel__eyebrow"
          >
            Explainability
          </p>
          <h2>
            How Personal Panchanga Is Different
          </h2>
          <p
            class="knowledge-panel__intro"
          >
            Personal Panchanga recalculates the day using your location and timezone, so sunrise-based results match your city, not only Kathmandu.
          </p>
        </header>
        <div
          class="knowledge-panel__sections"
        >
          <details
            class="knowledge-section"
            open=""
          >
            <summary>
              <span
                class="knowledge-section__title"
              >
                Inputs That Change the Result
              </span>
            </summary>
            <ul
              class="knowledge-terms"
            >
              <li
                class="knowledge-term"
              >
                <h3>
                  Latitude / Longitude
                </h3>
                <p>
                  Your physical location for sunrise and local sky calculations.
                </p>
                <p
                  class="knowledge-term__why"
                >
                  <strong>
                    Why it matters:
                  </strong>
                   
                  A tithi boundary can shift when sunrise changes by location.
                </p>
              </li>
              <li
                class="knowledge-term"
              >
                <h3>
                  Timezone
                </h3>
                <p>
                  Local civil time context for date boundaries and display.
                </p>
                <p
                  class="knowledge-term__why"
                >
                  <strong>
                    Why it matters:
                  </strong>
                   
                  Diaspora users get date labels aligned with their local day.
                </p>
              </li>
              <li
                class="knowledge-term"
              >
                <h3>
                  Method Profile
                </h3>
                <p>
                  Named ruleset used to compute this personal output.
                </p>
                <p
                  class="knowledge-term__why"
                >
                  <strong>
                    Why it matters:
                  </strong>
                   
                  Makes results auditable and consistent across clients.
                </p>
              </li>
            </ul>
          </details>
          <details
            class="knowledge-section"
          >
            <summary>
              <span
                class="knowledge-section__title"
              >
                The 5 Limbs of Panchanga
              </span>
              <span
                class="knowledge-section__description"
              >
                Each day is described using five markers:
              </span>
            </summary>
            <ul
              class="knowledge-terms"
            >
              <li
                class="knowledge-term"
              >
                <h3>
                  Tithi
                </h3>
                <p>
                  The lunar day based on Moon-Sun angle (1 to 30).
                </p>
                <p
                  class="knowledge-term__why"
                >
                  <strong>
                    Why it matters:
                  </strong>
                   
                  Most festivals and fasts are tied to a specific tithi at sunrise.
                </p>
              </li>
              <li
                class="knowledge-term"
              >
                <h3>
                  Nakshatra
                </h3>
                <p>
                  The Moon's star sector among 27 nakshatras.
                </p>
                <p
                  class="knowledge-term__why"
                >
                  <strong>
                    Why it matters:
                  </strong>
                   
                  Used in puja planning, naming traditions, and muhurta filtering.
                </p>
              </li>
              <li
                class="knowledge-term"
              >
                <h3>
                  Yoga
                </h3>
                <p>
                  A combined Sun-Moon angle classification among 27 yogas.
                </p>
                <p
                  class="knowledge-term__why"
                >
                  <strong>
                    Why it matters:
                  </strong>
                   
                  Traditionally used to classify general day quality.
                </p>
              </li>
              <li
                class="knowledge-term"
              >
                <h3>
                  Karana
                </h3>
                <p>
                  Half of a tithi; a finer time unit for action windows.
                </p>
                <p
                  class="knowledge-term__why"
                >
                  <strong>
                    Why it matters:
                  </strong>
                   
                  Useful when selecting specific periods within a day.
                </p>
              </li>
              <li
                class="knowledge-term"
              >
                <h3>
                  Vaara
                </h3>
                <p>
                  Weekday (Ravivara, Somavara, etc.).
                </p>
                <p
                  class="knowledge-term__why"
                >
                  <strong>
                    Why it matters:
                  </strong>
                   
                  Many rituals have weekday preferences or restrictions.
                </p>
              </li>
            </ul>
          </details>
        </div>
      </section>
    </div>
  </details>
</section>
`;

