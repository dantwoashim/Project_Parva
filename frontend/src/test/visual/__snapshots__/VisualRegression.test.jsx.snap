                </strong>
              </div>
              <small>
                2083 Ashwin 4
                 - 2083 Ashwin 14
              </small>
            </article>
            <article
              class="fd-rhythm__row"
            >
              <div>
                <span>
                  2027
                </span>
                <strong>
                  Oct 10, 2027
                   - Oct 20, 2027
                </strong>
              </div>
              <small>
                2084 Ashwin 23
                 - 2084 Kartik 2
              </small>
            </article>
          </div>
        </article>
      </div>
      <aside
        class="fd-sidebar"
      >
        <article
          class="ink-card fd-summary-panel"
        >
          <div
            class="fd-section-head"
          >
